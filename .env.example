# Environment Configuration Template
# Copy this file to .env and update with your values

# ==========================================
# Flask/FastAPI Configuration
# ==========================================
FLASK_ENV=development
DEBUG=False
SECRET_KEY=your-secret-key-here-generate-one

# Generate secure key:
# python -c "import secrets; print(secrets.token_urlsafe(32))"

# ==========================================
# Server Configuration
# ==========================================
HOST=0.0.0.0
PORT=5001
LOG_LEVEL=info

# ==========================================
# Database Configuration
# ==========================================
# For SQLite (default)
DATABASE_URL=sqlite:///database/stego_system.db

# For PostgreSQL (production recommended)
# DATABASE_URL=postgresql://user:password@localhost/steganography

# ==========================================
# Redis Configuration (Optional)
# ==========================================
REDIS_URL=redis://localhost:6379/0

# ==========================================
# Authentication
# ==========================================
JWT_SECRET_KEY=your-jwt-secret-key-here
JWT_ALGORITHM=HS256
JWT_EXPIRATION_HOURS=24

# ==========================================
# File Upload Configuration
# ==========================================
MAX_FILE_SIZE=524288000  # 500MB in bytes
ALLOWED_EXTENSIONS=.jpg,.jpeg,.png,.gif,.bmp,.tiff,.wav,.mp3,.mp4,.avi,.mov,.pdf,.docx

# ==========================================
# Security
# ==========================================
# CORS Origins (comma-separated)
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5001,http://127.0.0.1:3000

# Rate limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_PERIOD=3600  # seconds

# ==========================================
# Cryptography
# ==========================================
RSA_KEY_SIZE=2048
AES_KEY_SIZE=256
ENCRYPTION_ALGORITHM=AES-256-CBC

# ==========================================
# GPU Configuration (Optional)
# ==========================================
USE_GPU=False
CUDA_DEVICE=0
GPU_MEMORY_FRACTION=0.8

# ==========================================
# Steganography Configuration
# ==========================================
# Enable various algorithms
USE_STREAMING=True
USE_COMPRESSION=True
USE_OPTIMIZATION=True
MAX_WORKERS=4

# ==========================================
# Email Configuration (Optional)
# ==========================================
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=your-email@gmail.com
SMTP_PASSWORD=your-app-password
SMTP_FROM_EMAIL=noreply@steganography.app

# ==========================================
# Third-party Services
# ==========================================
# AWS S3 (for backup storage - optional)
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_STORAGE_BUCKET_NAME=your-bucket

# ==========================================
# Deployment Platform Specific
# ==========================================
# For Render.com
RENDER=false
RENDER_EXTERNAL_URL=https://your-service.onrender.com

# For Railway.sh
RAILWAY_ENVIRONMENT_NAME=production

# For Fly.io
FLY_APP_NAME=steganography

# ==========================================
# Logging
# ==========================================
LOG_FILE=logs/app.log
LOG_MAX_BYTES=10485760  # 10MB
LOG_BACKUP_COUNT=10

# ==========================================
# Application Features
# ==========================================
ENABLE_API_DOCS=True
ENABLE_ADMIN_DASHBOARD=True
ENABLE_USER_REGISTRATION=True
ENABLE_KEY_GENERATION=True

# ==========================================
# Performance Tuning
# ==========================================
# Connection pooling
DB_POOL_SIZE=5
DB_MAX_OVERFLOW=10

# Async workers
UVICORN_WORKERS=4
UVICORN_THREADS=2

# ==========================================
# Monitoring & Analytics (Optional)
# ==========================================
SENTRY_DSN=https://your-sentry-url
DATADOG_API_KEY=your-datadog-key
